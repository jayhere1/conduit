{
  "name": "conduit-vscode",
  "displayName": "Conduit Pipeline Orchestrator",
  "description": "VS Code extension for the Conduit pipeline orchestrator — compile, run, and visualize DAGs directly from your editor.",
  "version": "0.1.0",
  "publisher": "conduit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Visualization"
  ],
  "keywords": [
    "conduit",
    "DAG",
    "pipeline",
    "orchestrator",
    "data engineering"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.py"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conduit-explorer",
          "title": "Conduit",
          "icon": "$(git-merge)"
        }
      ]
    },
    "views": {
      "conduit-explorer": [
        {
          "id": "conduit.dagTree",
          "name": "Pipeline Explorer",
          "icon": "$(git-merge)",
          "contextualTitle": "Conduit"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "conduit.run",
          "when": "view == conduit.dagTree && viewItem == dag",
          "group": "inline@1"
        },
        {
          "command": "conduit.showGraph",
          "when": "view == conduit.dagTree && viewItem == dag",
          "group": "inline@2"
        },
        {
          "command": "conduit.showLineage",
          "when": "view == conduit.dagTree && viewItem == task",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "conduit.compile",
          "when": "view == conduit.dagTree",
          "group": "navigation"
        },
        {
          "command": "conduit.refreshTree",
          "when": "view == conduit.dagTree",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "conduit.compile",
        "title": "Conduit: Compile DAGs",
        "icon": "$(gear)"
      },
      {
        "command": "conduit.run",
        "title": "Conduit: Run DAG",
        "icon": "$(play)"
      },
      {
        "command": "conduit.plan",
        "title": "Conduit: Show Deployment Plan",
        "icon": "$(diff)"
      },
      {
        "command": "conduit.showGraph",
        "title": "Conduit: Show DAG Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "conduit.showLineage",
        "title": "Conduit: Show Task Lineage",
        "icon": "$(references)"
      },
      {
        "command": "conduit.refreshTree",
        "title": "Conduit: Refresh Explorer",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Conduit",
      "properties": {
        "conduit.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the conduit binary. Leave empty to use 'conduit' from PATH."
        },
        "conduit.dagsPath": {
          "type": "string",
          "default": "",
          "description": "Path to the DAGs directory. Leave empty to auto-detect from workspace."
        },
        "conduit.apiUrl": {
          "type": "string",
          "default": "http://localhost:9091/api/v1",
          "description": "URL of the Conduit API server."
        },
        "conduit.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compile DAGs when a Python file is saved."
        },
        "conduit.compileDebounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce interval in milliseconds for auto-compile on save."
        }
      }
    },
    "languages": [
      {
        "id": "python",
        "extensions": [
          ".py"
        ]
      }
    ]
  },
  "scripts": {
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "npm run compile -- --minify && vsce package",
    "lint": "tsc --noEmit",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
