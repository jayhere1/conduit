# ─── Conduit Docker Configuration ─────────────────────────────────────────────

# API server port (default: 9090)
CONDUIT_PORT=9090

# UI dev server port (default: 3000, only used in dev mode)
UI_PORT=3000

# Docs server port (default: 3001)
DOCS_PORT=3001

# Path to your DAG definitions on the host
CONDUIT_DAGS_PATH=./dags

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=conduit=info
